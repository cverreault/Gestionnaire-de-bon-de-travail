{
  "name": "taskmgr-backend",
  "version": "1.0.0",
  "description": "TaskMgr Backend — NestJS API for Work Order Management",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "arch:check": "depcruise src --config .dependency-cruiser.cjs",
    "arch:report": "depcruise src --config .dependency-cruiser.cjs --output-type html --output-to dependency-graph.html",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "test": "jest",
    "test:integration": "DATABASE_URL=\"postgresql://taskmgr:taskmgr_secret@localhost:5434/taskmgr_test\" THROTTLER_DISABLE=1 JWT_SECRET=test-jwt-secret JWT_REFRESH_SECRET=test-refresh-secret JWT_EXPIRATION=15m JWT_REFRESH_EXPIRATION=7d MINIO_ENDPOINT=localhost MINIO_PORT=9000 MINIO_ACCESS_KEY=test MINIO_SECRET_KEY=test MINIO_BUCKET=test SENTRY_DSN= LOG_LEVEL=silent jest --config jest.integration.config.js --runInBand"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "10.3.10",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.3.10",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.3.10",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "7.4.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "6.2.1",
    "@prisma/client": "5.17.0",
    "@sentry/node": "^10.62.0",
    "@types/nodemailer": "^8.0.1",
    "@types/web-push": "^3.6.4",
    "bcrypt": "5.1.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "compression": "1.7.4",
    "helmet": "7.1.0",
    "minio": "8.0.1",
    "multer": "1.4.5-lts.1",
    "nestjs-i18n": "^10.6.1",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.1",
    "otpauth": "^9.5.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pg": "8.12.0",
    "pino-http": "^11.0.0",
    "puppeteer-core": "^23.11.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "stripe": "^22.3.0",
    "tar": "7.4.3",
    "tar-stream": "3.1.7",
    "uuid": "10.0.0",
    "web-push": "^3.6.7"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.5",
    "@nestjs/schematics": "10.1.4",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "5.0.2",
    "@types/compression": "1.7.5",
    "@types/jest": "^30.0.0",
    "@types/multer": "1.4.11",
    "@types/node": "20.14.12",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/pg": "8.11.6",
    "@types/supertest": "^7.2.0",
    "@types/tar": "6.1.13",
    "@types/tar-stream": "3.1.4",
    "@types/uuid": "10.0.0",
    "dependency-cruiser": "^17.4.3",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "prisma": "5.17.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.5.4"
  }
}
