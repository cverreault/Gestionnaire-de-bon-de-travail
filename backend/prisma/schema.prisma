generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  /// Platform-level administrator (SA). Inherits every ADMIN privilege
  /// and additionally manages global system configs (SMTP, VAPID,
  /// Sentry…). When multi-tenancy lands, SA is the only role that can
  /// CRUD tenants. Bootstrapped via SUPER_ADMIN_EMAIL env on boot.
  SUPER_ADMIN
  ADMIN
  DISPATCHER
  TECHNICIAN
}

enum WorkOrderStatus {
  CREATED
  ASSIGNED
  DISPATCHED
  EN_ROUTE
  IN_PROGRESS
  COMPLETED_POSITIVE
  COMPLETED_NEGATIVE
}

enum WorkOrderType {
  INSTALLATION
  REPAIR
  MAINTENANCE
  INSPECTION
  OTHER
}

enum ClientType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  INSTITUTIONAL
}

enum AddressType {
  OFFICE
  WAREHOUSE
  RESIDENCE
  WORKSITE
}

enum TenantPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SystemConfigScope {
  GLOBAL
  TENANT
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Multi-tenancy root entity (B6).
///
/// One row per logical customer. Self-hosted deployments have a single
/// DEFAULT tenant (id `00000000-0000-0000-0000-000000000001`).
///
/// Quotas live here too — `max_*` are the ceilings, `current_*` are the
/// running counters maintained by QuotaService (B6.6). The monthly
/// reset cron flips `current_work_orders_this_month` back to 0 on the
/// 1st of each month.
model Tenant {
  id       String     @id @default(uuid())
  slug     String     @unique
  name     String
  isActive Boolean    @default(true) @map("is_active")
  plan     TenantPlan @default(FREE)

  // Quotas (B6.6)
  maxUsers              Int @default(3) @map("max_users")
  maxWorkOrdersPerMonth Int @default(50) @map("max_work_orders_per_month")
  maxStorageMb          Int @default(100) @map("max_storage_mb")
  maxClients            Int @default(50) @map("max_clients")

  currentUsers               Int       @default(0) @map("current_users")
  currentWorkOrdersThisMonth Int       @default(0) @map("current_work_orders_this_month")
  currentStorageBytes        BigInt    @default(0) @map("current_storage_bytes")
  currentClients             Int       @default(0) @map("current_clients")
  workOrdersResetAt          DateTime? @map("work_orders_reset_at")

  ownerEmail String? @map("owner_email")

  /// Branding (B7.5) — MinIO object key of the tenant logo (e.g.
  /// `tenants/<id>/logo.png`). Null = no custom logo, the UI falls back
  /// to the generic TaskMgr mark. The presigned URL is resolved on read.
  logoStorageKey String? @map("logo_storage_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  technicianLocations TechnicianLocation[]
  temporaryClients    TemporaryClient[]
  clients             Client[]
  clientAddresses     ClientAddress[]
  taskTypes           TaskType[]
  workOrderTemplates  WorkOrderTemplate[]
  templateSections    TemplateSection[]
  templateFields      TemplateField[]
  clientTypeConfigs   ClientTypeConfig[]
  addressTypeConfigs  AddressTypeConfig[]
  addressTypeFields   AddressTypeField[]
  workOrders          WorkOrder[]
  notes               Note[]
  attachments         Attachment[]
  appointments        Appointment[]
  processDefinitions  ProcessDefinition[]
  processStatuses     ProcessStatus[]
  processTransitions  ProcessTransition[]
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  systemConfigs       SystemConfig[]

  @@index([isActive], map: "idx_tenants_is_active")
  @@map("tenants")
}

model User {
  id        String  @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  email     String
  password  String
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  role      Role    @default(TECHNICIAN)
  isActive  Boolean @default(true) @map("is_active")
  phone     String?

  // Per-user UI preferences (column layouts, hidden filters, etc.) as free-form JSON.
  preferences Json?

  /// Email verification timestamp (B6.8). Null = unverified ; the
  /// account still works (soft enforcement) but the front-end shows
  /// a banner until verified_at is set.
  emailVerifiedAt DateTime? @map("email_verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignedWorkOrders   WorkOrder[]          @relation("AssignedTechnician")
  createdWorkOrders    WorkOrder[]          @relation("CreatedBy")
  notes                Note[]
  appointments         Appointment[]        @relation("TechnicianAppointments")
  locations            TechnicianLocation[]
  emailVerifications   EmailVerification[]

  @@unique([tenantId, email], map: "idx_users_tenant_email")
  @@index([tenantId], map: "idx_users_tenant_id")
  @@index([email], map: "idx_users_email")
  @@map("users")
}

/// Token table backing the /verify-email endpoint (B6.8).
///
/// The raw token is sent to the user by email and stored ONLY as a
/// SHA-256 hash, same posture as RefreshToken. Once `consumed_at` is
/// set, the token is dead.
model EmailVerification {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId], map: "idx_email_verifications_user_id")
  @@map("email_verifications")
}

/// Time-series of technician positions for live dispatch view (B5).
///
/// Append-only — old rows are pruned by a nightly cron (7-day retention,
/// PIPEDA/Loi 25 compliance). Opt-in via `User.preferences.gps.enabled`;
/// rows are only inserted when the front-end posts a position with that
/// flag set, so a tech who never opted in never produces rows.
///
/// The (technician_id, recorded_at DESC) index supports the most common
/// query: "give me the latest position for each tech right now" — the
/// dispatcher dashboard polls this every few seconds.
model TechnicianLocation {
  id           String   @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  technicianId String   @map("technician_id")
  technician   User     @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  latitude     Float
  longitude    Float
  /// Reported by the Geolocation API in metres. Null when the source
  /// didn't provide it (rare — desktop browsers sometimes omit).
  accuracy     Float?
  recordedAt   DateTime @default(now()) @map("recorded_at")

  @@index([technicianId, recordedAt(sort: Desc)], map: "idx_technician_locations_tech_recorded")
  @@index([recordedAt], map: "idx_technician_locations_recorded_at")
  @@index([tenantId], map: "idx_technician_locations_tenant_id")
  @@map("technician_locations")
}

model TemporaryClient {
  id         String  @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  firstName  String  @map("first_name")
  lastName   String  @map("last_name")
  email      String?
  phone      String?
  address    String?
  city       String?
  postalCode String? @map("postal_code")
  notes      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workOrders WorkOrder[]

  @@index([tenantId], map: "idx_temporary_clients_tenant_id")
  @@map("temporary_clients")
}

model Client {
  id          String     @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  firstName   String     @map("first_name")
  lastName    String     @map("last_name")
  companyName String?    @map("company_name")
  email       String?
  phone       String?
  clientType  ClientType @default(RESIDENTIAL) @map("client_type")
  notes       String?
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  addresses  ClientAddress[]
  workOrders WorkOrder[]

  @@index([clientType], map: "idx_clients_type")
  @@index([isActive], map: "idx_clients_is_active")
  @@index([tenantId], map: "idx_clients_tenant_id")
  @@map("clients")
}

model ClientAddress {
  id           String   @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  // Optional: a "standalone" address (e.g. site/location library) has no client.
  // It can be linked later via PATCH or used as-is for reference data.
  clientId     String?  @map("client_id")
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  streetNumber String?  @map("street_number")
  street       String
  apartment    String?
  city         String
  postalCode   String   @map("postal_code")
  province     String   @default("Québec")
  country      String   @default("Canada")
  // Free-form code matching AddressTypeConfig.code. Was previously a strict
  // enum (OFFICE/WAREHOUSE/RESIDENCE/WORKSITE) but is now configurable.
  addressType  String   @default("RESIDENCE") @map("address_type")
  label        String?
  isDefault    Boolean  @default(false) @map("is_default")
  latitude     Float?
  longitude    Float?
  // Free-form values for the custom fields defined on the matching AddressTypeConfig
  // (keyed by AddressTypeField.id). Mirrors WorkOrder.templateData on the templates side.
  typeData     Json?    @map("type_data")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workOrders WorkOrder[]

  @@index([clientId], map: "idx_client_addresses_client_id")
  @@index([tenantId], map: "idx_client_addresses_tenant_id")
  @@map("client_addresses")
}

model TaskType {
  id          String  @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  name        String
  prefix      String
  description String?
  color       String?
  icon        String?
  isActive    Boolean @default(true) @map("is_active")

  /// SLA in hours — if set, every BT of this type is expected to be
  /// completed within slaHours after creation. Null = no SLA tracked.
  /// Range [1, 4380] = 1 hour to 6 months (clamped at the DTO layer).
  slaHours Int? @map("sla_hours")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Process Engine ──
  processDefinitionId String?            @map("process_definition_id")
  processDefinition   ProcessDefinition? @relation(fields: [processDefinitionId], references: [id])

  // ── Form Template ──
  templateId String?            @map("template_id")
  template   WorkOrderTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  workOrders WorkOrder[]

  @@unique([tenantId, name], map: "idx_task_types_tenant_name")
  @@unique([tenantId, prefix], map: "idx_task_types_tenant_prefix")
  @@index([isActive], map: "idx_task_types_is_active")
  @@index([tenantId], map: "idx_task_types_tenant_id")
  @@map("task_types")
}

enum TemplateFieldType {
  // ── Texte ──
  TEXT
  TEXTAREA
  EMAIL
  URL

  // ── Numérique ──
  NUMBER // legacy: kept as a generic alias for FLOAT
  INTEGER
  FLOAT
  CURRENCY
  PERCENTAGE

  // ── Sélection ──
  CHECKBOX
  SELECT
  MULTISELECT
  RADIO

  // ── Date / heure ──
  DATE
  TIME
  DATETIME

  // ── Téléphone / code postal ──
  PHONE
  PHONE_NA
  POSTAL_CODE_CA

  // ── Géolocalisation ──
  GPS
}

model WorkOrderTemplate {
  id          String   @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sections  TemplateSection[]
  taskTypes TaskType[]

  @@unique([tenantId, name], map: "idx_work_order_templates_tenant_name")
  @@index([isActive], map: "idx_work_order_templates_is_active")
  @@index([tenantId], map: "idx_work_order_templates_tenant_id")
  @@map("work_order_templates")
}

model TemplateSection {
  id         String            @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  templateId String            @map("template_id")
  template   WorkOrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int               @default(0) @map("sort_order")
  viewRoles  Role[]            @default([ADMIN, DISPATCHER, TECHNICIAN]) @map("view_roles")
  editRoles  Role[]            @default([ADMIN, DISPATCHER, TECHNICIAN]) @map("edit_roles")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  fields TemplateField[]

  @@index([templateId], map: "idx_template_sections_template_id")
  @@index([tenantId], map: "idx_template_sections_tenant_id")
  @@map("template_sections")
}

model TemplateField {
  id            String            @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  sectionId     String            @map("section_id")
  section       TemplateSection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  label         String
  fieldType     TemplateFieldType @default(TEXT) @map("field_type")
  placeholder   String?
  helpText      String?           @map("help_text")
  options       Json?
  sortOrder     Int               @default(0) @map("sort_order")
  viewRoles     Role[]            @default([ADMIN, DISPATCHER, TECHNICIAN]) @map("view_roles")
  editRoles     Role[]            @default([ADMIN, DISPATCHER, TECHNICIAN]) @map("edit_roles")
  requiredRoles Role[]            @default([]) @map("required_roles")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([sectionId], map: "idx_template_fields_section_id")
  @@index([tenantId], map: "idx_template_fields_tenant_id")
  @@map("template_fields")
}

model ClientTypeConfig {
  id          String   @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  code        String
  description String?
  color       String?  @default("#3b82f6")
  icon        String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name], map: "idx_client_type_configs_tenant_name")
  @@unique([tenantId, code], map: "idx_client_type_configs_tenant_code")
  @@index([isActive], map: "idx_client_type_configs_is_active")
  @@index([tenantId], map: "idx_client_type_configs_tenant_id")
  @@map("client_type_configs")
}

model AddressTypeConfig {
  id                 String   @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  name               String
  code               String
  description        String?
  color              String?  @default("#3b82f6")
  icon               String?
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  // ID of the AddressTypeField designated as "predominant" — its value is shown
  // in large type when an address of this type is displayed (e.g. lot # for camping).
  predominantFieldId String?  @map("predominant_field_id")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  fields AddressTypeField[]

  @@unique([tenantId, name], map: "idx_address_type_configs_tenant_name")
  @@unique([tenantId, code], map: "idx_address_type_configs_tenant_code")
  @@index([isActive], map: "idx_address_type_configs_is_active")
  @@index([tenantId], map: "idx_address_type_configs_tenant_id")
  @@map("address_type_configs")
}

model AddressTypeField {
  id                  String            @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  addressTypeConfigId String            @map("address_type_config_id")
  addressTypeConfig   AddressTypeConfig @relation(fields: [addressTypeConfigId], references: [id], onDelete: Cascade)
  label               String
  // Reuses the TemplateFieldType enum from the form-template feature.
  fieldType           TemplateFieldType @default(TEXT) @map("field_type")
  required            Boolean           @default(false)
  options             Json?
  sortOrder           Int               @default(0) @map("sort_order")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@index([addressTypeConfigId], map: "idx_address_type_fields_config_id")
  @@index([tenantId], map: "idx_address_type_fields_tenant_id")
  @@map("address_type_fields")
}

model WorkOrder {
  id              String          @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  referenceNumber String          @map("reference_number")
  status          WorkOrderStatus @default(CREATED)
  type            WorkOrderType   @default(OTHER)
  title           String
  description     String?
  priority        Int             @default(0)

  // Client — either a temporary local client or a reference to external DB
  temporaryClientId  String?          @map("temporary_client_id")
  temporaryClient    TemporaryClient? @relation(fields: [temporaryClientId], references: [id])
  externalClientId   String?          @map("external_client_id")
  externalClientName String?          @map("external_client_name")
  clientAddress      String?          @map("client_address")

  // Nouveaux FK V3
  taskTypeId        String?        @map("task_type_id")
  taskType          TaskType?      @relation(fields: [taskTypeId], references: [id])
  clientId          String?        @map("client_id")
  client            Client?        @relation(fields: [clientId], references: [id])
  clientAddressId   String?        @map("client_address_id")
  clientAddress_rel ClientAddress? @relation(fields: [clientAddressId], references: [id])

  // ── Process Engine (double-colonne pendant transition) ──
  processDefinitionId String?            @map("process_definition_id")
  processDefinition   ProcessDefinition? @relation(fields: [processDefinitionId], references: [id])
  currentStepId       String?            @map("current_step_id")
  currentStep         ProcessStatus?     @relation(fields: [currentStepId], references: [id])

  // Assignation
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("AssignedTechnician", fields: [assignedToId], references: [id])
  createdById  String  @map("created_by_id")
  createdBy    User    @relation("CreatedBy", fields: [createdById], references: [id])

  // Scheduling
  scheduledDate      DateTime? @map("scheduled_date")
  scheduledStartTime DateTime? @map("scheduled_start_time")
  scheduledEndTime   DateTime? @map("scheduled_end_time")
  actualStartTime    DateTime? @map("actual_start_time")
  actualEndTime      DateTime? @map("actual_end_time")

  // Completion
  completionNotes String? @map("completion_notes")
  negativeReason  String? @map("negative_reason")

  // Form Template values — stored as { fieldId: value, ... }
  templateData Json? @map("template_data")

  dispatchedAt DateTime? @map("dispatched_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // SLA (B4) — slaTargetAt is computed at create from taskType.slaHours
  // and stays immutable; slaBreachedAt is set by SlaCheckService when
  // the BT is still active past the target.
  slaTargetAt   DateTime? @map("sla_target_at")
  slaBreachedAt DateTime? @map("sla_breached_at")

  notes        Note[]
  attachments  Attachment[]
  appointments Appointment[]

  @@index([status])
  @@index([assignedToId])
  @@index([scheduledDate])
  @@unique([tenantId, referenceNumber], map: "idx_work_orders_tenant_reference")
  @@index([referenceNumber])
  @@index([clientId], map: "idx_work_orders_client_id")
  @@index([taskTypeId], map: "idx_work_orders_task_type_id")
  @@index([processDefinitionId], map: "idx_work_orders_process_definition_id")
  /// Scan for un-breached BTs whose target has passed — partial index
  /// would be ideal but Prisma doesn't expose it; the cron filters on
  /// status anyway so this is fine.
  @@index([slaTargetAt, slaBreachedAt], map: "idx_work_orders_sla_pending")
  @@index([currentStepId], map: "idx_work_orders_current_step_id")
  @@index([tenantId], map: "idx_work_orders_tenant_id")
  @@map("work_orders")
}

model Note {
  id          String    @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  content     String
  workOrderId String    @map("work_order_id")
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  authorId    String    @map("author_id")
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId], map: "idx_notes_tenant_id")
  @@map("notes")
}

model Attachment {
  id          String    @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  fileName    String    @map("file_name")
  fileSize    Int       @map("file_size")
  mimeType    String    @map("mime_type")
  storageKey  String    @map("storage_key")
  workOrderId String    @map("work_order_id")
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  uploadedAt  DateTime  @default(now()) @map("uploaded_at")

  @@index([tenantId], map: "idx_attachments_tenant_id")
  @@map("attachments")
}

model Appointment {
  id           String     @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  title        String
  description  String?
  startTime    DateTime   @map("start_time")
  endTime      DateTime   @map("end_time")
  technicianId String?    @map("technician_id")
  technician   User?      @relation("TechnicianAppointments", fields: [technicianId], references: [id])
  workOrderId  String?    @map("work_order_id")
  workOrder    WorkOrder? @relation(fields: [workOrderId], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([startTime, endTime])
  @@index([technicianId])
  @@index([tenantId], map: "idx_appointments_tenant_id")
  @@map("appointments")
}

// ─── Process Engine ───────────────────────────────────────────────────────────

model ProcessDefinition {
  id          String  @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  version     Int     @default(1)
  isDefault   Boolean @default(false) @map("is_default")
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  statuses    ProcessStatus[]
  transitions ProcessTransition[]
  taskTypes   TaskType[]
  workOrders  WorkOrder[]

  @@unique([tenantId, name], map: "idx_process_definitions_tenant_name")
  @@index([isDefault], map: "idx_process_definitions_is_default")
  @@index([isActive], map: "idx_process_definitions_is_active")
  @@index([tenantId], map: "idx_process_definitions_tenant_id")
  @@map("process_definitions")
}

model ProcessStatus {
  id                  String            @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  processDefinitionId String            @map("process_definition_id")
  processDefinition   ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)

  code     Int
  name     String
  color    String @default("#6b7280")
  position Int

  isInitial          Boolean @default(false) @map("is_initial")
  isDispatch         Boolean @default(false) @map("is_dispatch")
  isStart            Boolean @default(false) @map("is_start")
  isTerminalPositive Boolean @default(false) @map("is_terminal_positive")
  isTerminalNegative Boolean @default(false) @map("is_terminal_negative")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transitionsFrom ProcessTransition[] @relation("FromStatus")
  transitionsTo   ProcessTransition[] @relation("ToStatus")
  workOrders      WorkOrder[]

  @@unique([processDefinitionId, code], map: "uq_process_status_definition_code")
  @@index([processDefinitionId], map: "idx_process_statuses_definition_id")
  @@index([position], map: "idx_process_statuses_position")
  @@index([tenantId], map: "idx_process_statuses_tenant_id")
  @@map("process_statuses")
}

model ProcessTransition {
  id                  String            @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  processDefinitionId String            @map("process_definition_id")
  processDefinition   ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)

  fromStatusId String        @map("from_status_id")
  fromStatus   ProcessStatus @relation("FromStatus", fields: [fromStatusId], references: [id])

  toStatusId String        @map("to_status_id")
  toStatus   ProcessStatus @relation("ToStatus", fields: [toStatusId], references: [id])

  label          String
  allowedRoles   Role[]
  requiredFields String[]
  sortOrder      Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([processDefinitionId, fromStatusId, toStatusId], map: "uq_process_transition_unique")
  @@index([processDefinitionId], map: "idx_process_transitions_definition_id")
  @@index([fromStatusId], map: "idx_process_transitions_from_status_id")
  @@index([tenantId], map: "idx_process_transitions_tenant_id")
  @@map("process_transitions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: Audit
// Voir : docs/adrs/ADR-007, plan §B2
// ─────────────────────────────────────────────────────────────────────────────

/// Trace immuable de chaque domain event passé dans le système.
///
/// Insertion uniquement — jamais d'UPDATE/DELETE (sauf purge Loi 25 manuelle).
/// Le module `audit` écoute tous les events `workOrders.*` (et autres futurs)
/// via @OnEvent et persiste un row par event.
///
/// Convention : un seul row = un seul event. L'analyse cross-event se fait
/// en SQL (filter par aggregate_id, ORDER BY occurred_at).
model AuditLog {
  // Identité de l'event
  id          String   @id @default(uuid()) // = IDomainEvent.eventId
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  eventName   String   @map("event_name") // ex: "workOrders.workOrder.assigned"
  aggregateId String   @map("aggregate_id") // ex: workOrderId
  occurredAt  DateTime @map("occurred_at") // = IDomainEvent.occurredAt

  // Acteur
  actorUserId String? @map("actor_user_id") // null pour events système

  // Payload de l'event (variable selon eventName)
  data Json? // = IDomainEvent.data

  // Timestamp serveur (peut différer de occurredAt si traitement async)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([aggregateId, occurredAt(sort: Desc)], map: "idx_audit_logs_aggregate_recent")
  @@index([eventName, occurredAt(sort: Desc)], map: "idx_audit_logs_event_recent")
  @@index([actorUserId, occurredAt(sort: Desc)], map: "idx_audit_logs_actor_recent")
  @@index([tenantId], map: "idx_audit_logs_tenant_id")
  @@map("audit_logs")
}

/// Platform-level system configuration (SA.1.b).
///
/// Key/value store for runtime overrides of what would otherwise live in
/// .env (SMTP, VAPID, Sentry DSN, retention windows…). Resolution order
/// at read time: this table → process.env → hardcoded default.
///
/// Secrets (SMTP_PASS, VAPID_PRIVATE, etc.) are stored AES-GCM encrypted
/// with a master key sourced from CONFIG_MASTER_KEY (env). The `encrypted`
/// flag tells the service whether to decrypt on read.
///
/// Multi-tenancy (B6): scope is either GLOBAL (operator-set defaults
/// like a SaaS-wide SMTP) or TENANT (per-customer overrides). Resolution
/// order: TENANT row > GLOBAL row > env > undefined.
model SystemConfig {
  id        String            @id @default(uuid())
  scope     SystemConfigScope @default(GLOBAL)
  tenantId  String?           @map("tenant_id") // NULL when scope=GLOBAL
  tenant    Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String // "smtp.host", "vapid.public-key", …
  value     String            @db.Text // ciphertext if `encrypted`, else raw UTF-8
  encrypted Boolean           @default(false)
  updatedBy String?           @map("updated_by") // userId who last wrote
  updatedAt DateTime          @updatedAt @map("updated_at")
  createdAt DateTime          @default(now()) @map("created_at")

  @@unique([tenantId, key], map: "idx_system_configs_tenant_key")
  @@index([tenantId], map: "idx_system_configs_tenant_id")
  @@map("system_configs")
}

/// Refresh tokens — DB-backed rotation chain.
///
/// Chaque login démarre une nouvelle famille. Chaque refresh révoque l'ancien
/// token et émet un nouveau de la même famille. Si un token déjà révoqué est
/// rejoué (replay attack), la famille entière est invalidée.
///
/// Le token brut n'est jamais stocké — seulement son SHA-256.
model RefreshToken {
  id       String @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  /// SHA-256 hex du JWT, pas le JWT lui-même (defense in depth).
  tokenHash String @unique @map("token_hash")

  /// Propriétaire — pas de FK cascade, on garde l'historique sur soft-delete user.
  userId String @map("user_id")

  /// UUID partagé par tous les tokens issus du même login (rotation chain).
  /// Si un token révoqué est rejoué, on révoque toute la famille.
  family String

  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  /// Set quand : rotation (refresh consomme l'ancien), logout, ou kill-switch
  /// (détection de replay → revoke toute la famille).
  revokedAt DateTime? @map("revoked_at")

  @@index([userId], map: "idx_refresh_tokens_user")
  @@index([family], map: "idx_refresh_tokens_family")
  @@index([expiresAt], map: "idx_refresh_tokens_expires")
  @@index([tenantId], map: "idx_refresh_tokens_tenant_id")
  @@map("refresh_tokens")
}

/// User notifications (B1).
///
/// Persisted per-user record produced by event listeners. The DB row is
/// the source of truth — channels (email, web push, in-app) are
/// delivery side-effects.
///
/// Statut lifecycle :
///   PENDING   → emitted, not yet attempted
///   SENT      → at least one channel succeeded
///   FAILED    → all attempted channels errored (kept for retry / debug)
///   READ      → user opened it in-app (only set by user action)
///
/// Channels are tracked as a JSON array on `channelsSent` so we can show
/// "Email + Push" badges in the UI without a side table.
model Notification {
  id       String @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  /// Recipient — no cascade : a deactivated user keeps their history.
  userId String @map("user_id")

  /// Categorical type — drives template + default channel selection.
  /// ex: "workOrder.assigned", "workOrder.completed", "auth.passwordReset"
  type String

  /// Free-form title shown in the badge/dropdown.
  title String

  /// Optional body — kept short for the in-app dropdown; emails get a
  /// fuller render via templates.
  body String?

  /// Aggregate the notification refers to (workOrderId, etc.) so the UI
  /// can deep-link.
  aggregateId String? @map("aggregate_id")

  /// Original event payload (kept for re-render / debug).
  data Json?

  /// PENDING / SENT / FAILED / READ (see model docstring).
  status String @default("PENDING")

  /// JSON array of channels that succeeded — ex: ["email", "push"].
  channelsSent Json? @map("channels_sent")

  /// Set on the first delivery (any channel).
  sentAt DateTime? @map("sent_at")

  /// Set when the user opens the notification in-app.
  readAt DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Inbox queries are by user + unread first.
  @@index([userId, readAt, createdAt(sort: Desc)], map: "idx_notifications_inbox")
  /// Background retries scan PENDING/FAILED.
  @@index([status, createdAt], map: "idx_notifications_status")
  @@index([tenantId], map: "idx_notifications_tenant_id")
  @@map("notifications")
}

/// Web Push subscriptions (B1.3).
///
/// One row per (user, browser/device). The endpoint is unique — the same
/// browser re-subscribing replaces the previous row via upsert in the
/// service.
///
/// p256dh + auth are the encryption keys the browser handed us during
/// PushManager.subscribe(); they're per-subscription, not per-user.
model PushSubscription {
  id       String @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  /// Owner.
  userId String @map("user_id")

  /// Endpoint URL returned by the browser PushManager. Unique per
  /// device — used to dedupe re-subscriptions.
  endpoint String @unique

  /// Browser-provided encryption keys.
  p256dh String
  auth   String

  /// Optional UA so we can show "Chrome on Linux" in a future UI.
  userAgent String? @map("user_agent")

  createdAt  DateTime  @default(now()) @map("created_at")
  /// Last time we attempted to send via this subscription.
  lastUsedAt DateTime? @map("last_used_at")

  @@index([userId], map: "idx_push_subscriptions_user")
  @@index([tenantId], map: "idx_push_subscriptions_tenant_id")
  @@map("push_subscriptions")
}
