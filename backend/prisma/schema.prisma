generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  /// Platform-level administrator (SA). Inherits every ADMIN privilege
  /// and additionally manages global system configs (SMTP, VAPID,
  /// Sentry…). When multi-tenancy lands, SA is the only role that can
  /// CRUD tenants. Bootstrapped via SUPER_ADMIN_EMAIL env on boot.
  SUPER_ADMIN
  ADMIN
  DISPATCHER
  TECHNICIAN
  /// End-customer portal account (B21). Linked to a Client record via
  /// User.clientId; sees only its own work orders through /portal/*.
  CLIENT
}

enum WorkOrderStatus {
  /// B21 — client-portal work request awaiting admin approval. Sits
  /// BEFORE the normal pipeline: approve → CREATED, reject → terminal.
  REQUESTED
  CREATED
  ASSIGNED
  DISPATCHED
  EN_ROUTE
  IN_PROGRESS
  COMPLETED_POSITIVE
  COMPLETED_NEGATIVE
}

enum WorkOrderType {
  INSTALLATION
  REPAIR
  MAINTENANCE
  INSPECTION
  OTHER
}

/// B24 — direction/nature of a stock movement. Quantities are always
/// positive; the type carries the sign.
enum StockMovementType {
  RECEIPT
  ADJUSTMENT
  TRANSFER_TO_TECH
  TRANSFER_TO_WAREHOUSE
  USAGE
  USAGE_REVERT
}

/// B24 — where a part used on a work order was taken from.
enum PartSource {
  WAREHOUSE
  TECHNICIAN_STOCK
}

enum ClientType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  INSTITUTIONAL
}

enum AddressType {
  OFFICE
  WAREHOUSE
  RESIDENCE
  WORKSITE
}

enum TenantPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SystemConfigScope {
  GLOBAL
  TENANT
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Multi-tenancy root entity (B6).
///
/// One row per logical customer. Self-hosted deployments have a single
/// DEFAULT tenant (id `00000000-0000-0000-0000-000000000001`).
///
/// Quotas live here too — `max_*` are the ceilings, `current_*` are the
/// running counters maintained by QuotaService (B6.6). The monthly
/// reset cron flips `current_work_orders_this_month` back to 0 on the
/// 1st of each month.
model Tenant {
  id       String     @id @default(uuid())
  slug     String     @unique
  name     String
  isActive Boolean    @default(true) @map("is_active")
  plan     TenantPlan @default(FREE)

  // Quotas (B6.6)
  maxUsers              Int @default(3) @map("max_users")
  maxWorkOrdersPerMonth Int @default(50) @map("max_work_orders_per_month")
  maxStorageMb          Int @default(100) @map("max_storage_mb")
  maxClients            Int @default(50) @map("max_clients")

  currentUsers               Int       @default(0) @map("current_users")
  currentWorkOrdersThisMonth Int       @default(0) @map("current_work_orders_this_month")
  currentStorageBytes        BigInt    @default(0) @map("current_storage_bytes")
  currentClients             Int       @default(0) @map("current_clients")
  workOrdersResetAt          DateTime? @map("work_orders_reset_at")

  ownerEmail String? @map("owner_email")

  /// B22 — Stripe billing linkage (set by the billing webhook once the
  /// tenant completes a Checkout). Null = never paid online.
  stripeCustomerId     String? @unique @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")

  /// Branding (B7.5) — MinIO object key of the tenant logo (e.g.
  /// `tenants/<id>/logo.png`). Null = no custom logo, the UI falls back
  /// to the generic TaskMgr mark. The presigned URL is resolved on read.
  logoStorageKey String? @map("logo_storage_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  technicianLocations TechnicianLocation[]
  temporaryClients    TemporaryClient[]
  clients             Client[]
  clientAddresses     ClientAddress[]
  taskTypes           TaskType[]
  workOrderTemplates  WorkOrderTemplate[]
  templateSections    TemplateSection[]
  templateFields      TemplateField[]
  clientTypeConfigs   ClientTypeConfig[]
  addressTypeConfigs  AddressTypeConfig[]
  addressTypeFields   AddressTypeField[]
  workOrders          WorkOrder[]
  notes               Note[]
  attachments         Attachment[]
  appointments        Appointment[]
  processDefinitions  ProcessDefinition[]
  processStatuses     ProcessStatus[]
  processTransitions  ProcessTransition[]
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  systemConfigs       SystemConfig[]
  monthlyPeaks        TenantMonthlyPeak[]
  apiKeys             ApiKey[]
  webhookEndpoints    WebhookEndpoint[]
  webhookDeliveries   WebhookDelivery[]
  alertRules          AlertRule[]
  recurringWorkOrders RecurringWorkOrder[]
  reminders           WorkOrderReminder[]
  portalInvitations   PortalInvitation[]
  parts               Part[]
  technicianPartStocks TechnicianPartStock[]
  stockMovements      StockMovement[]
  workOrderParts      WorkOrderPart[]

  @@index([isActive], map: "idx_tenants_is_active")
  @@map("tenants")
}

/// SaaS plan catalog — DB-backed so the SA can edit prices, quotas and
/// features from the UI without a redeploy (B7.8). Codes mirror the
/// `TenantPlan` enum and are the stable handle that `tenant.plan` joins on.
///
/// Adding a new code requires extending the enum in this schema first.
/// Editing existing rows is fully runtime — single source of truth lives
/// in `plans`.
model Plan {
  id                   String   @id @default(uuid())
  /// Stable handle. Must match a `TenantPlan` enum value.
  code                 TenantPlan @unique
  displayName          String   @map("display_name")
  tagline              String   @default("")
  description          String   @default("")

  /// Monthly base fee, billed regardless of seat count.
  priceMonthly         Decimal  @db.Decimal(10, 2) @default(0) @map("price_monthly")
  /// Additional charge per active user — e.g. 20 $/user/month. Total
  /// monthly = `priceMonthly + activeUsers * pricePerUserMonthly`.
  pricePerUserMonthly  Decimal  @db.Decimal(10, 2) @default(0) @map("price_per_user_monthly")
  currency             String   @default("CAD")

  /// Default quotas applied to a tenant when it lands on this plan.
  /// A tenant can have explicit overrides — the plan values are only
  /// templates, not enforced caps on the tenant row.
  maxUsers              Int     @map("max_users")
  maxWorkOrdersPerMonth Int     @map("max_work_orders_per_month")
  maxStorageMb          Int     @map("max_storage_mb")
  maxClients            Int     @map("max_clients")

  /// B22 — Stripe billing binding. The SA creates the recurring Price in
  /// the Stripe dashboard and pastes its id here (price_…). Null = this
  /// plan can't be bought online (manual/free flow only).
  stripePriceId        String?  @map("stripe_price_id")

  features             String[] @default([])
  recommended          Boolean  @default(false)
  sortOrder            Int      @default(0) @map("sort_order")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

/// Monthly usage peak per tenant per category (B7.12).
///
/// Tracks the HIGH-WATER MARK of each counter within a calendar month so
/// per-seat pricing can bill fairly on the month's peak, not on the count
/// at invoice time. A tenant that grew from 2 → 4 → 2 users pays for 4.
///
/// Rows are UPSERTed via `INSERT ... ON CONFLICT DO UPDATE SET max_X =
/// GREATEST(existing, EXCLUDED.max_X)` from `PeakTrackerService`. Peaks
/// only ever increase within a month; the next month gets a fresh row.
model TenantMonthlyPeak {
  id                     String   @id @default(uuid())
  tenantId               String   @map("tenant_id")
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Format `YYYY-MM` (kept as a fixed-length string for cheap indexing).
  yearMonth              String   @db.Char(7) @map("year_month")
  maxUsers               Int      @default(0) @map("max_users")
  maxClients             Int      @default(0) @map("max_clients")
  maxWorkOrdersThisMonth Int      @default(0) @map("max_work_orders_this_month")
  maxStorageBytes        BigInt   @default(0) @map("max_storage_bytes")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, yearMonth], map: "tenant_monthly_peaks_tenant_month_key")
  @@index([yearMonth], map: "idx_tenant_monthly_peaks_year_month")
  @@map("tenant_monthly_peaks")
}

/// Public-API authentication keys (B8).
///
/// Machine-to-machine access to the tenant's data through `/api/v1/*`.
/// The plaintext key (`tkm_<env>_<32-b64url>`) is shown ONCE at creation;
/// only its SHA-256 hash lives in the DB. Revocation is soft — we keep
/// the row for audit and to display a "revoked at" state in the admin UI.
///
/// Scope is a coarse bundle : `read-only` ⊂ `read-write` ⊂ `admin`. Fine
/// grained permissions are a v2 concern.
model ApiKey {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Human-facing label — "Zapier integration", "Internal CRM", …
  name            String
  /// SHA-256 hex of the full plaintext key. Lookup index for auth path.
  keyHash         String    @unique @map("key_hash")
  /// Visible prefix (first 16 chars) so admins can identify a key without
  /// knowing the full plaintext — mirrors the Stripe / GitHub pattern.
  keyPrefix       String    @map("key_prefix")
  /// One of `read-only` | `read-write` | `admin`. Enforced by ApiScopeGuard.
  scope           String
  /// null = never expires.
  expiresAt       DateTime? @map("expires_at")
  /// Soft-revoke — the row stays for audit; auth path rejects when set.
  revokedAt       DateTime? @map("revoked_at")
  /// Fire-and-forget bump on every successful request. Not indexed — read
  /// only in the admin UI, not on the hot path.
  lastUsedAt      DateTime? @map("last_used_at")
  /// User who minted the key (the ADMIN in most cases).
  createdByUserId String    @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId], map: "idx_api_keys_tenant_id")
  @@index([keyHash], map: "idx_api_keys_key_hash")
  @@map("api_keys")
}

/// Outbound-webhook subscription (B9).
///
/// One row per registered receiver URL. The tenant chooses which events to
/// receive via `subscribedEvents` (exact names or trailing-wildcard patterns
/// like `workOrders.*`). Only the SHA-256 hash of the signing secret is
/// stored — the plaintext (`whsec_<32-b64url>`) is shown ONCE at creation
/// and after every regenerate.
///
/// Payloads are signed Stripe-style: HMAC-SHA256 over `"<t>.<rawBody>"` with
/// the current secret, put in `X-TaskMgr-Signature: t=<t>,v1=<hex>`. Receivers
/// verify the signature AND check that `|now - t| ≤ 300s`.
///
/// Auto-disabling: after `consecutiveFailures` reaches 15, `isActive` flips
/// to false and `disabledReason` records why. The admin re-enables from the UI.
model WebhookEndpoint {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Human-facing label — "Zapier integration", "CRM sync", …
  name            String
  /// Destination URL. https:// enforced in production; http:// only for dev.
  url             String
  /// AES-256-GCM ciphertext of the plaintext signing secret (base64:
  /// `iv | authTag | ciphertext`). The dispatcher decrypts at delivery time
  /// to sign outbound requests. Master key comes from
  /// WEBHOOK_MASTER_KEY (env, hex-encoded 32 bytes) or falls back to a
  /// SHA-256 of JWT_SECRET when unset — allowing dev bring-up without extra
  /// config. In production, always set WEBHOOK_MASTER_KEY explicitly.
  secretEncrypted String    @map("secret_encrypted")
  /// Visible prefix (first 8 chars) so admins can identify a secret without
  /// knowing the full plaintext — mirrors ApiKey.keyPrefix.
  secretPrefix    String    @map("secret_prefix")
  /// Exact event names or trailing-wildcard patterns (`workOrders.*`, `*`).
  /// Matched in-process by WebhookFanoutListener.
  subscribedEvents String[] @map("subscribed_events")
  isActive        Boolean   @default(true) @map("is_active")
  /// Reason recorded when isActive was flipped to false by the system
  /// (currently only "auto-disabled after N consecutive failed deliveries").
  disabledReason  String?   @map("disabled_reason")
  /// Count of back-to-back failed deliveries. Reset to 0 on any 2xx response.
  consecutiveFailures Int   @default(0) @map("consecutive_failures")
  lastSuccessAt   DateTime? @map("last_success_at")
  lastFailureAt   DateTime? @map("last_failure_at")
  createdByUserId String    @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  deliveries      WebhookDelivery[]

  @@index([tenantId], map: "idx_webhook_endpoints_tenant_id")
  @@index([tenantId, isActive], map: "idx_webhook_endpoints_tenant_active")
  @@map("webhook_endpoints")
}

/// One delivery attempt log per (endpoint, event). Append-only within a row:
/// retries update the SAME row, they never insert a new one, so a receiver
/// getting the message twice is a genuine reprocessing (idempotent via `id`).
///
/// `payload` is frozen at fanout time — the receiver sees the state at
/// emission, not at delivery. This also keeps the HMAC signature valid
/// across retries.
model WebhookDelivery {
  id                    String    @id @default(uuid())
  tenantId              String    @map("tenant_id")
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpointId            String    @map("endpoint_id")
  endpoint              WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  /// The originating domain event UUID (from `IDomainEvent.eventId`).
  /// Same event fanned out to N endpoints creates N delivery rows.
  eventId               String    @map("event_id")
  eventName             String    @map("event_name")
  /// The exact JSON bytes we sign and POST. Immutable across retries.
  payload               Json
  /// `pending` | `succeeded` | `failed` | `abandoned`.
  status                String    @default("pending")
  attemptCount          Int       @default(0) @map("attempt_count")
  nextRetryAt           DateTime? @map("next_retry_at")
  lastResponseStatus    Int?      @map("last_response_status")
  /// First 512 chars of the receiver's response body. Truncated to protect
  /// against a receiver dumping a stack trace.
  lastResponseBodyExcerpt String? @map("last_response_body_excerpt")
  lastError             String?   @map("last_error")
  firstAttemptedAt      DateTime? @map("first_attempted_at")
  lastAttemptedAt       DateTime? @map("last_attempted_at")
  succeededAt           DateTime? @map("succeeded_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([status, nextRetryAt], map: "idx_webhook_deliveries_status_next_retry")
  @@index([endpointId, createdAt(sort: Desc)], map: "idx_webhook_deliveries_endpoint_created")
  @@map("webhook_deliveries")
}

/// Configurable alert rule (B10).
///
/// Tenant admins define « when event X on a work order matching filters Y,
/// notify recipients Z via channels C with template T ». The AlertsListener
/// catches every workOrders.** event, runs the rule engine to find matches,
/// resolves recipients (internal users + optionally the client), renders the
/// templates, and dispatches to each channel via the existing notifications
/// module.
///
/// See ADR-013 for the design tradeoffs (event-name filtering over per-
/// transition column, {{path}} templating over Handlebars, SMS stubbed for
/// v1, distinct client-facing template pair).
model AlertRule {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String  @default("")
  isActive    Boolean @default(true) @map("is_active")

  // ─── Trigger ────────────────────────────────────────────────────
  /// The exact domain event name — see WO_EVENT_NAMES. On any workOrders.**
  /// event, we match rules with this eventName equal to the fired event.
  eventName   String  @map("event_name")

  /// Scope (applies mainly to statusChanged — nulls = "any").
  processDefinitionId String? @map("process_definition_id")
  fromStatusId        String? @map("from_status_id")
  toStatusId          String? @map("to_status_id")

  /// Filters (empty array = no filter). Each acts as a whitelist — the
  /// event must match one of the listed values.
  taskTypeIds       String[] @default([]) @map("task_type_ids")
  /// Workorder templates (`WorkOrderTemplate.id`).
  templateIds       String[] @default([]) @map("template_ids")
  /// Client types — codes matching the `ClientType` enum
  /// (RESIDENTIAL / COMMERCIAL / INDUSTRIAL / INSTITUTIONAL).
  clientTypeCodes   String[] @default([]) @map("client_type_codes")
  /// Address types — string codes matching `ClientAddress.addressType`
  /// (defined per-tenant via `AddressTypeConfig`).
  addressTypeCodes  String[] @default([]) @map("address_type_codes")
  priorityIn        String[] @default([]) @map("priority_in")

  // ─── Recipients ─────────────────────────────────────────────────
  recipientRoles              Role[]   @default([]) @map("recipient_roles")
  recipientUserIds            String[] @default([]) @map("recipient_user_ids")
  recipientAssignedTechnician Boolean  @default(false) @map("recipient_assigned_technician")
  /// External — reads Client.email/phone at dispatch time.
  recipientClient             Boolean  @default(false) @map("recipient_client")

  // ─── Channels ───────────────────────────────────────────────────
  /// Must contain ≥ 1 of: 'inApp' | 'email' | 'sms' | 'push'.
  /// SMS is stubbed in v1 (see SmsChannelService).
  channels String[] @default([]) @map("channels")

  // ─── Templates ──────────────────────────────────────────────────
  /// Supports {{workOrder.referenceNumber}}, {{workOrder.title}},
  /// {{transition.from}}, {{transition.to}}, {{technician.name}},
  /// {{client.name}}, {{tenant.name}}. Missing paths render as empty.
  titleTemplate String @map("title_template")
  bodyTemplate  String @map("body_template")
  /// Distinct external-facing pair when recipientClient=true — never leak
  /// internal identifiers or statuses to the customer.
  clientTitleTemplate String? @map("client_title_template")
  clientBodyTemplate  String? @map("client_body_template")

  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([tenantId, isActive], map: "idx_alert_rules_tenant_active")
  @@index([tenantId, eventName], map: "idx_alert_rules_tenant_event")
  @@map("alert_rules")
}

/// Recurring work-order definition (B11).
///
/// A « template » BT the system spawns on a schedule (weekly / monthly /
/// custom). Used for maintenance contracts, periodic inspections, seasonal
/// prep. Each occurrence is a normal WorkOrder that flows through the
/// standard process — the recurrence only handles the spawning cadence.
///
/// Schedule model (simple, expressive):
///   - `frequency`      DAILY | WEEKLY | MONTHLY | YEARLY
///   - `interval`       Number of `frequency` units between runs
///                      (e.g. WEEKLY interval=2 → every 2 weeks).
///   - `byDayOfWeek`    Only for WEEKLY. Array of ints 0-6 (Sun-Sat).
///                      Empty = anchor day = startDate's weekday.
///   - `byDayOfMonth`   Only for MONTHLY. Array of ints 1-31.
///                      Empty = anchor day = startDate's day.
///   - `startDate`      Anchor. First occurrence is at/after this.
///   - `endDate`        Nullable. If set, no run after this date.
///   - `nextRunAt`      Materialised — the exact timestamp the Cron watches
///                      to decide « spawn now? ». Recomputed on each spawn.
///   - `lastRunAt`      Bookkeeping; also shown in the UI.
///
/// The Cron sweeper picks up rows where `isActive AND nextRunAt <= NOW()`,
/// creates a WorkOrder, then advances `nextRunAt`. The spawner is
/// idempotent-ish: two concurrent runs won't dupe because we update
/// `nextRunAt` atomically before creating the WO.
model RecurringWorkOrder {
  id              String  @id @default(uuid())
  tenantId        String  @map("tenant_id")
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Human-facing label — « Inspection annuelle chauffage acme ».
  name            String
  description     String  @default("")
  isActive        Boolean @default(true) @map("is_active")

  // ── Template inputs for the WOs to spawn ──────────────────────
  /// Task type — required (drives prefix, template, SLA).
  taskTypeId          String  @map("task_type_id")
  clientId            String  @map("client_id")
  clientAddressId     String? @map("client_address_id")
  /// Default assignee (optional). If null, spawned WO starts unassigned.
  assignedToId        String? @map("assigned_to_id")
  /// Title for the spawned WO. Supports {{date}} placeholder → replaced
  /// with the run date at spawn time.
  workOrderTitle      String  @default("") @map("work_order_title")
  workOrderDescription String @default("") @map("work_order_description")
  priority            Int    @default(0)

  // ── Schedule ──────────────────────────────────────────────────
  /// DAILY | WEEKLY | MONTHLY | YEARLY.
  frequency        String
  /// e.g. WEEKLY interval=2 → every 2 weeks. Range [1, 366].
  interval         Int      @default(1)
  /// Applies only when frequency=WEEKLY. Empty = anchor's weekday.
  byDayOfWeek      Int[]    @default([]) @map("by_day_of_week")
  /// Applies only when frequency=MONTHLY. Empty = anchor's day of month.
  byDayOfMonth     Int[]    @default([]) @map("by_day_of_month")
  startDate        DateTime @map("start_date")
  endDate          DateTime? @map("end_date")

  nextRunAt        DateTime  @map("next_run_at")
  lastRunAt        DateTime? @map("last_run_at")
  /// Count of successful spawns.
  spawnedCount     Int       @default(0) @map("spawned_count")

  createdByUserId  String   @map("created_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([tenantId, isActive], map: "idx_recurring_wo_tenant_active")
  @@index([isActive, nextRunAt], map: "idx_recurring_wo_next_run")
  @@map("recurring_work_orders")
}

/// Scheduled reminder for a work order (B15).
///
/// One row per (WO × trigger). When `sendAt` comes due, the Cron sweeper
/// picks the row up, renders the template, dispatches on the requested
/// channels, marks the row as sent.
///
/// Two creation paths :
///   1. Auto — WorkOrdersService, on WO create with `scheduledDate`, spawns
///      N reminders at configurable offsets (default: 24 h and 1 h before).
///   2. Manual — dispatcher schedules a one-off from the WO detail page
///      via POST /work-orders/:id/reminders.
model WorkOrderReminder {
  id           String  @id @default(uuid())
  tenantId     String  @map("tenant_id")
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workOrderId  String  @map("work_order_id")
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  /// When the reminder fires. UTC.
  sendAt       DateTime @map("send_at")

  /// Channels to fan out on when the reminder fires. Values from
  /// `['inApp', 'email', 'sms']`. `push` intentionally omitted — reminders
  /// go to the CLIENT most of the time, and the client doesn't have a
  /// browser push subscription.
  channels     String[] @default([])

  /// Optional custom message. When null, a default template is rendered:
  /// « Rappel : rendez-vous BT <reference> le <date> ».
  bodyTemplate String?  @map("body_template")

  /// `pending` | `sent` | `failed` | `cancelled`.
  status       String   @default("pending")
  sentAt       DateTime? @map("sent_at")
  errorMessage String?  @map("error_message")

  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([status, sendAt], map: "idx_wo_reminders_status_send_at")
  @@index([workOrderId], map: "idx_wo_reminders_wo_id")
  @@index([tenantId], map: "idx_wo_reminders_tenant_id")
  @@map("wo_reminders")
}

model User {
  id        String  @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  // B14 — 2FA/TOTP (RFC 6238). `totpSecret` = base32 secret encrypted at
  // rest via `secret-crypto` (same helper as webhook signing secrets).
  // `totpEnabled` flips true only after the user verifies the first code.
  // `totpBackupCodesHash` = SHA-256 of one-time recovery codes (10 codes,
  // one-line separated hashed) — used when the user loses their device.
  totpSecret          String?   @map("totp_secret")
  totpEnabled         Boolean   @default(false) @map("totp_enabled")
  totpBackupCodesHash String?   @map("totp_backup_codes_hash")
  totpEnabledAt       DateTime? @map("totp_enabled_at")
  // B26 — per-user 2FA brute-force lock: consecutive wrong codes and a
  // temporary lockout window (defence beyond the per-IP throttle).
  totpFailedAttempts  Int       @default(0) @map("totp_failed_attempts")
  totpLockedUntil     DateTime? @map("totp_locked_until")
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  email     String
  password  String
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  role      Role    @default(TECHNICIAN)
  isActive  Boolean @default(true) @map("is_active")
  phone     String?

  /// B21 — set only for role=CLIENT portal accounts: the Client record
  /// this login belongs to. One client can have several portal users.
  clientId String? @map("client_id")
  client   Client? @relation("ClientPortalUsers", fields: [clientId], references: [id], onDelete: SetNull)

  // Per-user UI preferences (column layouts, hidden filters, etc.) as free-form JSON.
  preferences Json?

  /// Email verification timestamp (B6.8). Null = unverified ; the
  /// account still works (soft enforcement) but the front-end shows
  /// a banner until verified_at is set.
  emailVerifiedAt DateTime? @map("email_verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignedWorkOrders   WorkOrder[]          @relation("AssignedTechnician")
  createdWorkOrders    WorkOrder[]          @relation("CreatedBy")
  notes                Note[]
  appointments         Appointment[]        @relation("TechnicianAppointments")
  locations            TechnicianLocation[]
  emailVerifications   EmailVerification[]
  portalInvitations    PortalInvitation[]
  technicianPartStocks TechnicianPartStock[] @relation("TechnicianPartStocks")
  technicianStockMovements StockMovement[]   @relation("TechnicianStockMovements")
  createdStockMovements    StockMovement[]   @relation("CreatedStockMovements")
  addedWorkOrderParts      WorkOrderPart[]   @relation("AddedWorkOrderParts")

  @@unique([tenantId, email], map: "idx_users_tenant_email")
  @@index([tenantId], map: "idx_users_tenant_id")
  @@index([email], map: "idx_users_email")
  @@index([clientId], map: "idx_users_client_id")
  @@map("users")
}

/// Token table backing the /verify-email endpoint (B6.8).
///
/// The raw token is sent to the user by email and stored ONLY as a
/// SHA-256 hash, same posture as RefreshToken. Once `consumed_at` is
/// set, the token is dead.
model EmailVerification {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId], map: "idx_email_verifications_user_id")
  @@map("email_verifications")
}

/// B21 — client-portal invitation token. Same posture as
/// EmailVerification: the raw token travels by email only, the DB keeps
/// a SHA-256 hash. Consuming the token sets the portal user's password.
model PortalInvitation {
  id         String    @id @default(uuid())
  tenantId   String    @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  clientId   String    @map("client_id")
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([clientId], map: "idx_portal_invitations_client_id")
  @@index([userId], map: "idx_portal_invitations_user_id")
  @@index([tenantId], map: "idx_portal_invitations_tenant_id")
  @@map("portal_invitations")
}

/// B24 — parts catalog. `quantityOnHand` is the WAREHOUSE aggregate;
/// truck quantities live in TechnicianPartStock. All stock math goes
/// through StockMovement rows inside a single transaction.
model Part {
  id       String @id @default(uuid())
  tenantId String @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  sku         String
  /// Bilingual pair (B10.2) — legacy `name` synced from FR by middleware.
  name        String
  nameFr      String  @default("") @map("name_fr")
  nameEn      String  @default("") @map("name_en")
  description String?
  /// Unité de mesure affichée (un, m, kg, boîte…).
  unit        String  @default("un")

  costPrice Decimal @db.Decimal(10, 2) @default(0) @map("cost_price")
  salePrice Decimal @db.Decimal(10, 2) @default(0) @map("sale_price")

  quantityOnHand Int @default(0) @map("quantity_on_hand")
  /// Low-stock alert threshold on the warehouse quantity. 0 = no alert.
  minStock       Int @default(0) @map("min_stock")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  technicianStocks TechnicianPartStock[]
  movements        StockMovement[]
  workOrderParts   WorkOrderPart[]

  @@unique([tenantId, sku], map: "uq_parts_tenant_sku")
  @@index([tenantId], map: "idx_parts_tenant_id")
  @@index([isActive], map: "idx_parts_is_active")
  @@map("parts")
}

/// B24 — per-technician (truck) stock. Separate table rather than a
/// nullable location column: Postgres unique constraints treat NULLs as
/// distinct, which would allow duplicate warehouse rows.
model TechnicianPartStock {
  id           String @id @default(uuid())
  tenantId     String @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant       Tenant @relation(fields: [tenantId], references: [id])
  partId       String @map("part_id")
  part         Part   @relation(fields: [partId], references: [id], onDelete: Cascade)
  technicianId String @map("technician_id")
  technician   User   @relation("TechnicianPartStocks", fields: [technicianId], references: [id], onDelete: Cascade)
  quantity     Int    @default(0)
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([partId, technicianId], map: "uq_tech_part_stock")
  @@index([technicianId], map: "idx_tech_part_stock_technician")
  @@index([tenantId], map: "idx_tech_part_stock_tenant_id")
  @@map("technician_part_stocks")
}

/// B24 — append-only stock journal. Every quantity change (receipt,
/// adjustment, transfer, usage on a WO, usage revert) writes one row in
/// the same transaction that updates the aggregates.
model StockMovement {
  id       String @id @default(uuid())
  tenantId String @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  partId   String @map("part_id")
  part     Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  type     StockMovementType
  /// Always > 0 — the type carries the direction. ADJUSTMENT may be
  /// negative (delta stored as-is for that type only).
  quantity Int

  technicianId String? @map("technician_id")
  technician   User?   @relation("TechnicianStockMovements", fields: [technicianId], references: [id], onDelete: SetNull)
  workOrderId  String? @map("work_order_id")
  workOrder    WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  note        String?
  createdById String   @map("created_by_id")
  createdBy   User     @relation("CreatedStockMovements", fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([partId, createdAt(sort: Desc)], map: "idx_stock_movements_part_created")
  @@index([tenantId], map: "idx_stock_movements_tenant_id")
  @@map("stock_movements")
}

/// B24 — part consumed on a work order. Prices are SNAPSHOTS taken at
/// insert time so cost reports reflect what the part was worth when it
/// was used, not today's catalog price. (Internal cost data only —
/// Dispatch2Go does no invoicing.)
model WorkOrderPart {
  id          String    @id @default(uuid())
  tenantId    String    @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  workOrderId String    @map("work_order_id")
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  partId      String    @map("part_id")
  part        Part      @relation(fields: [partId], references: [id])

  quantity      Int
  source        PartSource @default(WAREHOUSE)
  /// Truck the part came from when source = TECHNICIAN_STOCK — needed to
  /// credit the right stock back on delete.
  technicianId  String?    @map("technician_id")
  unitCostPrice Decimal    @db.Decimal(10, 2) @default(0) @map("unit_cost_price")
  unitSalePrice Decimal    @db.Decimal(10, 2) @default(0) @map("unit_sale_price")

  addedById String   @map("added_by_id")
  addedBy   User     @relation("AddedWorkOrderParts", fields: [addedById], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@index([workOrderId], map: "idx_work_order_parts_wo")
  @@index([tenantId], map: "idx_work_order_parts_tenant_id")
  @@map("work_order_parts")
}

/// Time-series of technician positions for live dispatch view (B5).
///
/// Append-only — old rows are pruned by a nightly cron (7-day retention,
/// PIPEDA/Loi 25 compliance). Opt-in via `User.preferences.gps.enabled`;
/// rows are only inserted when the front-end posts a position with that
/// flag set, so a tech who never opted in never produces rows.
///
/// The (technician_id, recorded_at DESC) index supports the most common
/// query: "give me the latest position for each tech right now" — the
/// dispatcher dashboard polls this every few seconds.
model TechnicianLocation {
  id           String   @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  technicianId String   @map("technician_id")
  technician   User     @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  latitude     Float
  longitude    Float
  /// Reported by the Geolocation API in metres. Null when the source
  /// didn't provide it (rare — desktop browsers sometimes omit).
  accuracy     Float?
  recordedAt   DateTime @default(now()) @map("recorded_at")

  @@index([technicianId, recordedAt(sort: Desc)], map: "idx_technician_locations_tech_recorded")
  @@index([recordedAt], map: "idx_technician_locations_recorded_at")
  @@index([tenantId], map: "idx_technician_locations_tenant_id")
  @@map("technician_locations")
}

model TemporaryClient {
  id         String  @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  firstName  String  @map("first_name")
  lastName   String  @map("last_name")
  email      String?
  phone      String?
  address    String?
  city       String?
  postalCode String? @map("postal_code")
  notes      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workOrders WorkOrder[]

  @@index([tenantId], map: "idx_temporary_clients_tenant_id")
  @@map("temporary_clients")
}

model Client {
  id          String     @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  firstName   String     @map("first_name")
  lastName    String     @map("last_name")
  companyName String?    @map("company_name")
  email       String?
  phone       String?
  clientType  ClientType @default(RESIDENTIAL) @map("client_type")
  notes       String?
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  addresses   ClientAddress[]
  workOrders  WorkOrder[]
  portalUsers User[]             @relation("ClientPortalUsers")
  portalInvitations PortalInvitation[]

  @@index([clientType], map: "idx_clients_type")
  @@index([isActive], map: "idx_clients_is_active")
  @@index([tenantId], map: "idx_clients_tenant_id")
  @@map("clients")
}

model ClientAddress {
  id           String   @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  // Optional: a "standalone" address (e.g. site/location library) has no client.
  // It can be linked later via PATCH or used as-is for reference data.
  clientId     String?  @map("client_id")
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  streetNumber String?  @map("street_number")
  street       String
  apartment    String?
  city         String
  postalCode   String   @map("postal_code")
  province     String   @default("Québec")
  country      String   @default("Canada")
  // Free-form code matching AddressTypeConfig.code. Was previously a strict
  // enum (OFFICE/WAREHOUSE/RESIDENCE/WORKSITE) but is now configurable.
  addressType  String   @default("RESIDENCE") @map("address_type")
  label        String?
  isDefault    Boolean  @default(false) @map("is_default")
  latitude     Float?
  longitude    Float?
  // Free-form values for the custom fields defined on the matching AddressTypeConfig
  // (keyed by AddressTypeField.id). Mirrors WorkOrder.templateData on the templates side.
  typeData     Json?    @map("type_data")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workOrders WorkOrder[]

  @@index([clientId], map: "idx_client_addresses_client_id")
  @@index([tenantId], map: "idx_client_addresses_tenant_id")
  @@map("client_addresses")
}

model TaskType {
  id          String  @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  /// B10.2 — legacy `name` kept for back-compat; new writes should populate
  /// nameFr + nameEn. Reads pick based on Accept-Language with fallback.
  name        String
  /// Bilingual name — FR canonical (used to backfill legacy `name`).
  nameFr      String  @default("") @map("name_fr")
  nameEn      String  @default("") @map("name_en")
  prefix      String
  description String?
  descriptionFr String? @map("description_fr")
  descriptionEn String? @map("description_en")
  color       String?
  icon        String?
  isActive    Boolean @default(true) @map("is_active")

  /// SLA in hours — if set, every BT of this type is expected to be
  /// completed within slaHours after creation. Null = no SLA tracked.
  /// Range [1, 4380] = 1 hour to 6 months (clamped at the DTO layer).
  slaHours Int? @map("sla_hours")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Process Engine ──
  processDefinitionId String?            @map("process_definition_id")
  processDefinition   ProcessDefinition? @relation(fields: [processDefinitionId], references: [id])

  // ── Form Template ──
  templateId String?            @map("template_id")
  template   WorkOrderTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  workOrders WorkOrder[]

  @@unique([tenantId, name], map: "idx_task_types_tenant_name")
  @@unique([tenantId, prefix], map: "idx_task_types_tenant_prefix")
  @@index([isActive], map: "idx_task_types_is_active")
  @@index([tenantId], map: "idx_task_types_tenant_id")
  @@map("task_types")
}

enum TemplateFieldType {
  // ── Texte ──
  TEXT
  TEXTAREA
  EMAIL
  URL

  // ── Numérique ──
  NUMBER // legacy: kept as a generic alias for FLOAT
  INTEGER
  FLOAT
  CURRENCY
  PERCENTAGE

  // ── Sélection ──
  CHECKBOX
  SELECT
  MULTISELECT
  RADIO

  // ── Date / heure ──
  DATE
  TIME
  DATETIME

  // ── Téléphone / code postal ──
  PHONE
  PHONE_NA
  POSTAL_CODE_CA

  // ── Géolocalisation ──
  GPS
}

model WorkOrderTemplate {
  id          String   @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  nameFr      String   @default("") @map("name_fr")
  nameEn      String   @default("") @map("name_en")
  description String?
  descriptionFr String? @map("description_fr")
  descriptionEn String? @map("description_en")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sections  TemplateSection[]
  taskTypes TaskType[]

  @@unique([tenantId, name], map: "idx_work_order_templates_tenant_name")
  @@index([isActive], map: "idx_work_order_templates_is_active")
  @@index([tenantId], map: "idx_work_order_templates_tenant_id")
  @@map("work_order_templates")
}

model TemplateSection {
  id         String            @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  templateId String            @map("template_id")
  template   WorkOrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  nameFr     String            @default("") @map("name_fr")
  nameEn     String            @default("") @map("name_en")
  sortOrder  Int               @default(0) @map("sort_order")
  viewRoles  Role[]            @default([ADMIN, DISPATCHER, TECHNICIAN]) @map("view_roles")
  editRoles  Role[]            @default([ADMIN, DISPATCHER, TECHNICIAN]) @map("edit_roles")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  fields TemplateField[]

  @@index([templateId], map: "idx_template_sections_template_id")
  @@index([tenantId], map: "idx_template_sections_tenant_id")
  @@map("template_sections")
}

model TemplateField {
  id            String            @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  sectionId     String            @map("section_id")
  section       TemplateSection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  label         String
  labelFr       String            @default("") @map("label_fr")
  labelEn       String            @default("") @map("label_en")
  fieldType     TemplateFieldType @default(TEXT) @map("field_type")
  placeholder   String?
  helpText      String?           @map("help_text")
  options       Json?
  sortOrder     Int               @default(0) @map("sort_order")
  viewRoles     Role[]            @default([ADMIN, DISPATCHER, TECHNICIAN]) @map("view_roles")
  editRoles     Role[]            @default([ADMIN, DISPATCHER, TECHNICIAN]) @map("edit_roles")
  requiredRoles Role[]            @default([]) @map("required_roles")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([sectionId], map: "idx_template_fields_section_id")
  @@index([tenantId], map: "idx_template_fields_tenant_id")
  @@map("template_fields")
}

model ClientTypeConfig {
  id          String   @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  nameFr      String   @default("") @map("name_fr")
  nameEn      String   @default("") @map("name_en")
  code        String
  description String?
  descriptionFr String? @map("description_fr")
  descriptionEn String? @map("description_en")
  color       String?  @default("#3b82f6")
  icon        String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name], map: "idx_client_type_configs_tenant_name")
  @@unique([tenantId, code], map: "idx_client_type_configs_tenant_code")
  @@index([isActive], map: "idx_client_type_configs_is_active")
  @@index([tenantId], map: "idx_client_type_configs_tenant_id")
  @@map("client_type_configs")
}

model AddressTypeConfig {
  id                 String   @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  name               String
  nameFr             String   @default("") @map("name_fr")
  nameEn             String   @default("") @map("name_en")
  code               String
  description        String?
  descriptionFr      String?  @map("description_fr")
  descriptionEn      String?  @map("description_en")
  color              String?  @default("#3b82f6")
  icon               String?
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  // ID of the AddressTypeField designated as "predominant" — its value is shown
  // in large type when an address of this type is displayed (e.g. lot # for camping).
  predominantFieldId String?  @map("predominant_field_id")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  fields AddressTypeField[]

  @@unique([tenantId, name], map: "idx_address_type_configs_tenant_name")
  @@unique([tenantId, code], map: "idx_address_type_configs_tenant_code")
  @@index([isActive], map: "idx_address_type_configs_is_active")
  @@index([tenantId], map: "idx_address_type_configs_tenant_id")
  @@map("address_type_configs")
}

model AddressTypeField {
  id                  String            @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  addressTypeConfigId String            @map("address_type_config_id")
  addressTypeConfig   AddressTypeConfig @relation(fields: [addressTypeConfigId], references: [id], onDelete: Cascade)
  label               String
  labelFr             String            @default("") @map("label_fr")
  labelEn             String            @default("") @map("label_en")
  // Reuses the TemplateFieldType enum from the form-template feature.
  fieldType           TemplateFieldType @default(TEXT) @map("field_type")
  required            Boolean           @default(false)
  options             Json?
  sortOrder           Int               @default(0) @map("sort_order")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@index([addressTypeConfigId], map: "idx_address_type_fields_config_id")
  @@index([tenantId], map: "idx_address_type_fields_tenant_id")
  @@map("address_type_fields")
}

model WorkOrder {
  id              String          @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  referenceNumber String          @map("reference_number")
  status          WorkOrderStatus @default(CREATED)
  type            WorkOrderType   @default(OTHER)
  title           String
  description     String?
  priority        Int             @default(0)

  // Client — either a temporary local client or a reference to external DB
  temporaryClientId  String?          @map("temporary_client_id")
  temporaryClient    TemporaryClient? @relation(fields: [temporaryClientId], references: [id])
  externalClientId   String?          @map("external_client_id")
  externalClientName String?          @map("external_client_name")
  clientAddress      String?          @map("client_address")

  // Nouveaux FK V3
  taskTypeId        String?        @map("task_type_id")
  taskType          TaskType?      @relation(fields: [taskTypeId], references: [id])
  clientId          String?        @map("client_id")
  client            Client?        @relation(fields: [clientId], references: [id])
  clientAddressId   String?        @map("client_address_id")
  clientAddress_rel ClientAddress? @relation(fields: [clientAddressId], references: [id])

  // ── Process Engine (double-colonne pendant transition) ──
  processDefinitionId String?            @map("process_definition_id")
  processDefinition   ProcessDefinition? @relation(fields: [processDefinitionId], references: [id])
  currentStepId       String?            @map("current_step_id")
  currentStep         ProcessStatus?     @relation(fields: [currentStepId], references: [id])

  // Assignation
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("AssignedTechnician", fields: [assignedToId], references: [id])
  createdById  String  @map("created_by_id")
  createdBy    User    @relation("CreatedBy", fields: [createdById], references: [id])

  // Scheduling
  scheduledDate      DateTime? @map("scheduled_date")
  scheduledStartTime DateTime? @map("scheduled_start_time")
  scheduledEndTime   DateTime? @map("scheduled_end_time")
  actualStartTime    DateTime? @map("actual_start_time")
  actualEndTime      DateTime? @map("actual_end_time")

  // Completion
  completionNotes String? @map("completion_notes")
  negativeReason  String? @map("negative_reason")

  // B12 — Client + technician signatures captured at completion.
  // Stored as data-URL strings (base64 PNG, ~5–20 KB each). Nullable —
  // signature capture is optional and can happen after status change.
  signatureClient       String?   @map("signature_client")
  signatureTechnician   String?   @map("signature_technician")
  signedAt              DateTime? @map("signed_at")

  // Form Template values — stored as { fieldId: value, ... }
  templateData Json? @map("template_data")

  dispatchedAt DateTime? @map("dispatched_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // SLA (B4) — slaTargetAt is computed at create from taskType.slaHours
  // and stays immutable; slaBreachedAt is set by SlaCheckService when
  // the BT is still active past the target.
  slaTargetAt   DateTime? @map("sla_target_at")
  slaBreachedAt DateTime? @map("sla_breached_at")

  notes        Note[]
  attachments  Attachment[]
  appointments Appointment[]
  reminders    WorkOrderReminder[]
  partsUsed    WorkOrderPart[]
  stockMovements StockMovement[]

  @@index([status])
  @@index([assignedToId])
  @@index([scheduledDate])
  @@unique([tenantId, referenceNumber], map: "idx_work_orders_tenant_reference")
  @@index([referenceNumber])
  @@index([clientId], map: "idx_work_orders_client_id")
  @@index([taskTypeId], map: "idx_work_orders_task_type_id")
  @@index([processDefinitionId], map: "idx_work_orders_process_definition_id")
  /// Scan for un-breached BTs whose target has passed — partial index
  /// would be ideal but Prisma doesn't expose it; the cron filters on
  /// status anyway so this is fine.
  @@index([slaTargetAt, slaBreachedAt], map: "idx_work_orders_sla_pending")
  @@index([currentStepId], map: "idx_work_orders_current_step_id")
  @@index([tenantId], map: "idx_work_orders_tenant_id")
  @@map("work_orders")
}

model Note {
  id          String    @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  content     String
  workOrderId String    @map("work_order_id")
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  authorId    String    @map("author_id")
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId], map: "idx_notes_tenant_id")
  @@map("notes")
}

model Attachment {
  id          String    @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  fileName    String    @map("file_name")
  fileSize    Int       @map("file_size")
  mimeType    String    @map("mime_type")
  storageKey  String    @map("storage_key")
  workOrderId String    @map("work_order_id")
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  uploadedAt  DateTime  @default(now()) @map("uploaded_at")

  @@index([tenantId], map: "idx_attachments_tenant_id")
  @@map("attachments")
}

model Appointment {
  id           String     @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  title        String
  description  String?
  startTime    DateTime   @map("start_time")
  endTime      DateTime   @map("end_time")
  technicianId String?    @map("technician_id")
  technician   User?      @relation("TechnicianAppointments", fields: [technicianId], references: [id])
  workOrderId  String?    @map("work_order_id")
  workOrder    WorkOrder? @relation(fields: [workOrderId], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([startTime, endTime])
  @@index([technicianId])
  @@index([tenantId], map: "idx_appointments_tenant_id")
  @@map("appointments")
}

// ─── Process Engine ───────────────────────────────────────────────────────────

model ProcessDefinition {
  id          String  @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  version     Int     @default(1)
  isDefault   Boolean @default(false) @map("is_default")
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  statuses    ProcessStatus[]
  transitions ProcessTransition[]
  taskTypes   TaskType[]
  workOrders  WorkOrder[]

  @@unique([tenantId, name], map: "idx_process_definitions_tenant_name")
  @@index([isDefault], map: "idx_process_definitions_is_default")
  @@index([isActive], map: "idx_process_definitions_is_active")
  @@index([tenantId], map: "idx_process_definitions_tenant_id")
  @@map("process_definitions")
}

model ProcessStatus {
  id                  String            @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  processDefinitionId String            @map("process_definition_id")
  processDefinition   ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)

  code     Int
  name     String
  nameFr   String @default("") @map("name_fr")
  nameEn   String @default("") @map("name_en")
  color    String @default("#6b7280")
  position Int

  isInitial          Boolean @default(false) @map("is_initial")
  isDispatch         Boolean @default(false) @map("is_dispatch")
  isStart            Boolean @default(false) @map("is_start")
  isTerminalPositive Boolean @default(false) @map("is_terminal_positive")
  isTerminalNegative Boolean @default(false) @map("is_terminal_negative")
  /// B21 — pre-approval step for client-portal work requests. Work
  /// orders created via the portal start here instead of isInitial.
  isRequested        Boolean @default(false) @map("is_requested")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transitionsFrom ProcessTransition[] @relation("FromStatus")
  transitionsTo   ProcessTransition[] @relation("ToStatus")
  workOrders      WorkOrder[]

  @@unique([processDefinitionId, code], map: "uq_process_status_definition_code")
  @@index([processDefinitionId], map: "idx_process_statuses_definition_id")
  @@index([position], map: "idx_process_statuses_position")
  @@index([tenantId], map: "idx_process_statuses_tenant_id")
  @@map("process_statuses")
}

model ProcessTransition {
  id                  String            @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  processDefinitionId String            @map("process_definition_id")
  processDefinition   ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)

  fromStatusId String        @map("from_status_id")
  fromStatus   ProcessStatus @relation("FromStatus", fields: [fromStatusId], references: [id])

  toStatusId String        @map("to_status_id")
  toStatus   ProcessStatus @relation("ToStatus", fields: [toStatusId], references: [id])

  label          String
  labelFr        String   @default("") @map("label_fr")
  labelEn        String   @default("") @map("label_en")
  allowedRoles   Role[]
  requiredFields String[]
  sortOrder      Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([processDefinitionId, fromStatusId, toStatusId], map: "uq_process_transition_unique")
  @@index([processDefinitionId], map: "idx_process_transitions_definition_id")
  @@index([fromStatusId], map: "idx_process_transitions_from_status_id")
  @@index([tenantId], map: "idx_process_transitions_tenant_id")
  @@map("process_transitions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: Audit
// Voir : docs/adrs/ADR-007, plan §B2
// ─────────────────────────────────────────────────────────────────────────────

/// Trace immuable de chaque domain event passé dans le système.
///
/// Insertion uniquement — jamais d'UPDATE/DELETE (sauf purge Loi 25 manuelle).
/// Le module `audit` écoute tous les events `workOrders.*` (et autres futurs)
/// via @OnEvent et persiste un row par event.
///
/// Convention : un seul row = un seul event. L'analyse cross-event se fait
/// en SQL (filter par aggregate_id, ORDER BY occurred_at).
model AuditLog {
  // Identité de l'event
  id          String   @id @default(uuid()) // = IDomainEvent.eventId
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  eventName   String   @map("event_name") // ex: "workOrders.workOrder.assigned"
  aggregateId String   @map("aggregate_id") // ex: workOrderId
  occurredAt  DateTime @map("occurred_at") // = IDomainEvent.occurredAt

  // Acteur
  actorUserId String? @map("actor_user_id") // null pour events système

  // Payload de l'event (variable selon eventName)
  data Json? // = IDomainEvent.data

  // Timestamp serveur (peut différer de occurredAt si traitement async)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([aggregateId, occurredAt(sort: Desc)], map: "idx_audit_logs_aggregate_recent")
  @@index([eventName, occurredAt(sort: Desc)], map: "idx_audit_logs_event_recent")
  @@index([actorUserId, occurredAt(sort: Desc)], map: "idx_audit_logs_actor_recent")
  @@index([tenantId], map: "idx_audit_logs_tenant_id")
  @@map("audit_logs")
}

/// Platform-level system configuration (SA.1.b).
///
/// Key/value store for runtime overrides of what would otherwise live in
/// .env (SMTP, VAPID, Sentry DSN, retention windows…). Resolution order
/// at read time: this table → process.env → hardcoded default.
///
/// Secrets (SMTP_PASS, VAPID_PRIVATE, etc.) are stored AES-GCM encrypted
/// with a master key sourced from CONFIG_MASTER_KEY (env). The `encrypted`
/// flag tells the service whether to decrypt on read.
///
/// Multi-tenancy (B6): scope is either GLOBAL (operator-set defaults
/// like a SaaS-wide SMTP) or TENANT (per-customer overrides). Resolution
/// order: TENANT row > GLOBAL row > env > undefined.
model SystemConfig {
  id        String            @id @default(uuid())
  scope     SystemConfigScope @default(GLOBAL)
  tenantId  String?           @map("tenant_id") // NULL when scope=GLOBAL
  tenant    Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String // "smtp.host", "vapid.public-key", …
  value     String            @db.Text // ciphertext if `encrypted`, else raw UTF-8
  encrypted Boolean           @default(false)
  updatedBy String?           @map("updated_by") // userId who last wrote
  updatedAt DateTime          @updatedAt @map("updated_at")
  createdAt DateTime          @default(now()) @map("created_at")

  @@unique([tenantId, key], map: "idx_system_configs_tenant_key")
  @@index([tenantId], map: "idx_system_configs_tenant_id")
  @@map("system_configs")
}

/// Refresh tokens — DB-backed rotation chain.
///
/// Chaque login démarre une nouvelle famille. Chaque refresh révoque l'ancien
/// token et émet un nouveau de la même famille. Si un token déjà révoqué est
/// rejoué (replay attack), la famille entière est invalidée.
///
/// Le token brut n'est jamais stocké — seulement son SHA-256.
model RefreshToken {
  id       String @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  /// SHA-256 hex du JWT, pas le JWT lui-même (defense in depth).
  tokenHash String @unique @map("token_hash")

  /// Propriétaire — pas de FK cascade, on garde l'historique sur soft-delete user.
  userId String @map("user_id")

  /// UUID partagé par tous les tokens issus du même login (rotation chain).
  /// Si un token révoqué est rejoué, on révoque toute la famille.
  family String

  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  /// Set quand : rotation (refresh consomme l'ancien), logout, ou kill-switch
  /// (détection de replay → revoke toute la famille).
  revokedAt DateTime? @map("revoked_at")

  @@index([userId], map: "idx_refresh_tokens_user")
  @@index([family], map: "idx_refresh_tokens_family")
  @@index([expiresAt], map: "idx_refresh_tokens_expires")
  @@index([tenantId], map: "idx_refresh_tokens_tenant_id")
  @@map("refresh_tokens")
}

/// User notifications (B1).
///
/// Persisted per-user record produced by event listeners. The DB row is
/// the source of truth — channels (email, web push, in-app) are
/// delivery side-effects.
///
/// Statut lifecycle :
///   PENDING   → emitted, not yet attempted
///   SENT      → at least one channel succeeded
///   FAILED    → all attempted channels errored (kept for retry / debug)
///   READ      → user opened it in-app (only set by user action)
///
/// Channels are tracked as a JSON array on `channelsSent` so we can show
/// "Email + Push" badges in the UI without a side table.
model Notification {
  id       String @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  /// Recipient — no cascade : a deactivated user keeps their history.
  userId String @map("user_id")

  /// Categorical type — drives template + default channel selection.
  /// ex: "workOrder.assigned", "workOrder.completed", "auth.passwordReset"
  type String

  /// Free-form title shown in the badge/dropdown.
  title String

  /// Optional body — kept short for the in-app dropdown; emails get a
  /// fuller render via templates.
  body String?

  /// Aggregate the notification refers to (workOrderId, etc.) so the UI
  /// can deep-link.
  aggregateId String? @map("aggregate_id")

  /// Original event payload (kept for re-render / debug).
  data Json?

  /// PENDING / SENT / FAILED / READ (see model docstring).
  status String @default("PENDING")

  /// JSON array of channels that succeeded — ex: ["email", "push"].
  channelsSent Json? @map("channels_sent")

  /// Set on the first delivery (any channel).
  sentAt DateTime? @map("sent_at")

  /// Set when the user opens the notification in-app.
  readAt DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Inbox queries are by user + unread first.
  @@index([userId, readAt, createdAt(sort: Desc)], map: "idx_notifications_inbox")
  /// Background retries scan PENDING/FAILED.
  @@index([status, createdAt], map: "idx_notifications_status")
  @@index([tenantId], map: "idx_notifications_tenant_id")
  @@map("notifications")
}

/// Web Push subscriptions (B1.3).
///
/// One row per (user, browser/device). The endpoint is unique — the same
/// browser re-subscribing replaces the previous row via upsert in the
/// service.
///
/// p256dh + auth are the encryption keys the browser handed us during
/// PushManager.subscribe(); they're per-subscription, not per-user.
model PushSubscription {
  id       String @id @default(uuid())
  tenantId   String   @default("00000000-0000-0000-0000-000000000001") @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  /// Owner.
  userId String @map("user_id")

  /// Endpoint URL returned by the browser PushManager. Unique per
  /// device — used to dedupe re-subscriptions.
  endpoint String @unique

  /// Browser-provided encryption keys.
  p256dh String
  auth   String

  /// Optional UA so we can show "Chrome on Linux" in a future UI.
  userAgent String? @map("user_agent")

  createdAt  DateTime  @default(now()) @map("created_at")
  /// Last time we attempted to send via this subscription.
  lastUsedAt DateTime? @map("last_used_at")

  @@index([userId], map: "idx_push_subscriptions_user")
  @@index([tenantId], map: "idx_push_subscriptions_tenant_id")
  @@map("push_subscriptions")
}
