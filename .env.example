# ─── Multi-tenant base domain (B7.5) ─────────────────────────────────────────
# Each tenant is reached at <slug>.<VITE_BASE_DOMAIN>. Used by the frontend
# for the subdomain preview on the create-tenant page, and is the domain your
# wildcard DNS + nginx server_name must cover. VITE_* is baked at build time —
# rebuild the frontend (docker compose up --build -d frontend) after changing.
VITE_BASE_DOMAIN=taskmgr.local

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://taskmgr:taskmgr_secret@postgres:5432/taskmgr
EXTERNAL_DB_URL=postgresql://readonly:password@external-host:5432/clients

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── MinIO (S3-compatible) ────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=taskmgr-attachments

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:8088
# Additional origins allowed to call the public API v1 (comma-separated).
# The internal UI at CORS_ORIGIN is always allowed. Machine callers use
# X-API-Key auth so they don't need credentials — leave this empty in
# self-hosted single-integrator setups. Example :
# PUBLIC_API_CORS_ORIGINS=https://integrator1.example.com,https://integrator2.example.com
PUBLIC_API_CORS_ORIGINS=

# ─── Public API v1 rate limits ────────────────────────────────────────────────
# Applied per API key (falling back to IP for anonymous callers). Three
# named buckets — a request must fit under all three or gets a 429.
# Defaults tuned for a typical M2M integration ; dial them up for high-
# throughput integrators.
PUBLIC_API_THROTTLE_SHORT=30       # req/s
PUBLIC_API_THROTTLE_MEDIUM=300     # req/10s
PUBLIC_API_THROTTLE_LONG=3000      # req/min

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Audit retention (Loi 25 / PIPEDA) ────────────────────────────────────────
# Days to keep audit_logs entries. Clamped to [30, 3650]. Defaults to 365.
# Cleanup runs nightly at 03:30 — see modules/audit/audit-cleanup.service.ts
AUDIT_RETENTION_DAYS=365

# ─── Boot smoke test (C11) ────────────────────────────────────────────────────
# Set to 1 to skip the DB + MinIO probes that gate app.listen(). Default OFF.
# BOOT_SMOKE_DISABLE=1

# ─── Sentry (C10) — optional ──────────────────────────────────────────────────
# Leave SENTRY_DSN unset to disable error tracking entirely. Get the DSN
# from your Sentry project's "Client Keys (DSN)" page.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Notifications email (B1.1.c) — optional ─────────────────────────────────
# Leave SMTP_HOST unset to log emails to the backend console instead of
# sending them (useful for local dev). Once SMTP_HOST is set, the
# notifications listener delivers via nodemailer.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# NOTIFICATIONS_FROM="TaskMgr <noreply@yourdomain.com>"

# ─── Notifications Web Push (B1.3) — optional ────────────────────────────────
# Generate keys once with `npx web-push generate-vapid-keys`. Without both
# keys the push channel runs in CONSOLE mode and only logs the payload.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:noreply@yourdomain.com

# ─── Super-admin (SA.1.a) ─────────────────────────────────────────────────────
# Email of an existing user. At boot, if no SUPER_ADMIN exists in the DB,
# the matching user gets auto-promoted from their current role.
# SUPER_ADMIN_EMAIL=admin@yourdomain.com

# ─── System config encryption (SA.1.b) ───────────────────────────────────────
# 32-byte hex key (generate with `openssl rand -hex 32`). Used by AES-GCM to
# encrypt secrets stored in system_configs (SMTP_PASS, VAPID_PRIVATE_KEY, ...).
# Without this var, encrypted writes are rejected (plain values still work).
# Rotate at your peril — encrypted values become unreadable.
# CONFIG_MASTER_KEY=
